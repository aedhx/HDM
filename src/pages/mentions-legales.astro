---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { site, heroPhone } from "../data/site";
import { buildGraph, breadcrumbSchema } from "../data/schema";

const phoneDisplay = heroPhone();

const schema = buildGraph([
  breadcrumbSchema([
    { name: "Accueil", url: `${site.url}/` },
    { name: "Mentions légales", url: `${site.url}/mentions-legales/` },
  ]),
]);
---

<BaseLayout
  title="Mentions légales — HDM Menuiserie"
  description="Mentions légales et informations sur HDM Hugo Di Murro Menuiserie, artisan menuisier à Givors (69700)."
  noindex={true}
  schema={schema}
>
  <Nav />
  <main class="mentions">
    <div class="mentions-inner">
      <h1>Mentions légales</h1>

      <h2>Éditeur du site</h2>
      <p>
        <strong>{site.legalName}</strong> ({site.legal.legalForm})<br />
        Représentée par {site.legal.director}, {site.legal.directorRole}<br />
        Siège social : {site.street}, {site.postalCode} {site.city} — {site.region}, France
      </p>
      <ul>
        <li>Téléphone : <a href={`tel:${site.phone}`}>{phoneDisplay}</a></li>
        <li>Email : <a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>SIREN : {site.legal.siren}</li>
        <li>SIRET (siège) : {site.legal.siret}</li>
        <li>TVA intracommunautaire : {site.legal.vatId}</li>
        <li>Code APE/NAF : {site.legal.naf} — {site.legal.nafLabel}</li>
        <li>Date de création : {new Date(site.legal.foundedAt).toLocaleDateString("fr-FR")}</li>
        {site.legal.capital && <li>Capital social : {site.legal.capital}</li>}
        <li>Assurance RC professionnelle et garantie décennale : attestations sur demande</li>
      </ul>

      <h2>Hébergement</h2>
      <p>
        Site hébergé par <strong>Netlify, Inc.</strong> — 44 Montgomery Street, Suite 300, San Francisco, California 94104, USA — <a href="https://www.netlify.com" target="_blank" rel="noopener noreferrer">netlify.com</a>.
      </p>

      <h2>Propriété intellectuelle</h2>
      <p>
        L'ensemble du contenu du site (textes, photographies, logos, charte graphique) est la propriété de {site.name}. Toute reproduction, totale ou partielle, est interdite sans autorisation écrite préalable.
      </p>

      <h2>Données personnelles</h2>
      <p>
        Les données saisies dans le formulaire de contact (nom, prénom, téléphone, email, description du projet) sont collectées uniquement pour répondre à votre demande de devis. Elles sont conservées au maximum 3 ans à compter du dernier contact, puis supprimées.
      </p>
      <p>
        Conformément au <abbr title="Règlement général sur la protection des données">RGPD</abbr>, vous disposez d'un droit d'accès, de rectification et de suppression de vos données. Pour l'exercer, écrivez à <a href={`mailto:${site.email}`}>{site.email}</a>.
      </p>

      <h2>Cookies</h2>
      <p>
        Ce site n'utilise aucun cookie de traçage publicitaire. Il n'embarque aucun outil de mesure d'audience nécessitant un consentement préalable.
      </p>

      <h2>Crédits</h2>
      <p>
        Photographies : {site.name}. Polices : Cormorant Garamond et DM Sans (Google Fonts, licence OFL).
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
