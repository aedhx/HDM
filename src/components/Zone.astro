---
const mainCities = ["Givors", "Vienne (38)"];
const otherCities = [
  "Loire sur Rhône",
  "Grigny",
  "Chasse-sur-Rhône",
  "Ternay",
  "Saint-Symphorien-d'Ozon",
  "Millery",
  "Chonas-l'Amballan",
  "Reventin-Vaugris",
];
---

<section class="zone" id="zone">
  <div class="zone-inner">
    <div>
      <p class="section-label">Secteur</p>
      <h2 class="section-title">Zone<br />d'intervention</h2>
      <p class="zone-text">
        Basé à Givors (69700), j'interviens sur l'ensemble du secteur Rhône
        Sud et Vienne, sans frais de déplacement supplémentaires dans un rayon
        de 30 km.
      </p>
      <div class="zone-cities">
        {mainCities.map((c) => <span class="zone-tag main">{c}</span>)}
        {otherCities.map((c) => <span class="zone-tag">{c}</span>)}
      </div>
      <p style="margin-top: 1.5rem; font-size: 0.8rem; color: rgba(247,242,234,0.4);">
        Intervention possible au-delà sur devis. N'hésitez pas à me contacter.
      </p>
    </div>

    <div class="zone-map" aria-label="Carte stylisée du secteur d'intervention HDM autour de Givors">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
        <path
          d="M100,20 Q120,40 110,70 Q130,90 120,120 Q140,150 120,180"
          stroke="#C4956A"
          stroke-width="3"
          fill="none"
          stroke-linecap="round"
        />
        <circle cx="108" cy="115" r="8" fill="#bf1b2c" opacity="0.95" />
        <circle cx="108" cy="115" r="14" fill="#bf1b2c" opacity="0.25" class="pulse" />
        <circle cx="118" cy="145" r="6" fill="rgba(247,242,234,0.55)" />
        <circle cx="105" cy="100" r="4" fill="rgba(247,242,234,0.3)" />
        <circle cx="102" cy="90" r="4" fill="rgba(247,242,234,0.3)" />
        <text x="122" y="118" fill="#C4956A" font-size="10" font-family="serif" font-style="italic">Givors</text>
        <text x="128" y="148" fill="rgba(247,242,234,0.6)" font-size="9" font-family="serif">Vienne</text>
        <circle
          cx="108"
          cy="115"
          r="55"
          stroke="#C4956A"
          stroke-width="1"
          fill="none"
          stroke-dasharray="4,4"
          opacity="0.35"
        />
      </svg>
    </div>
  </div>
</section>
