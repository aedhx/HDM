---
import { Image } from "astro:assets";
import zoneMapImg from "../assets/images/zone-map.png";

const mainCities = ["Givors", "Vienne (38)"];
const otherCities = [
  "Loire sur Rhône",
  "Grigny",
  "Chasse-sur-Rhône",
  "Ternay",
  "Saint-Symphorien-d'Ozon",
  "Millery",
  "Chonas-l'Amballan",
  "Reventin-Vaugris",
];
---

<section class="zone" id="zone">
  <div class="zone-inner">
    <div>
      <p class="section-label">Secteur</p>
      <h2 class="section-title">Zone<br />d'intervention</h2>
      <p class="zone-text">
        Basé à Givors (69700), j'interviens sur l'ensemble du secteur Rhône
        Sud et Vienne, sans frais de déplacement supplémentaires dans un rayon
        de 30 km.
      </p>
      <div class="zone-cities">
        {mainCities.map((c) => <span class="zone-tag main">{c}</span>)}
        {otherCities.map((c) => <span class="zone-tag">{c}</span>)}
      </div>
      <p style="margin-top: 1.5rem; font-size: 0.8rem; color: rgba(247,242,234,0.4);">
        Intervention possible au-delà sur devis. N'hésitez pas à me contacter.
      </p>
    </div>

    <div class="zone-map">
      <Image
        src={zoneMapImg}
        alt="Carte du secteur d'intervention HDM Menuiserie : rayon de 30 km autour de Givors couvrant Vienne, Loire-sur-Rhône, Grigny, Chasse-sur-Rhône et les communes alentour"
        widths={[600, 900, 1200]}
        sizes="(max-width: 900px) 100vw, 600px"
        format="webp"
        quality={75}
        loading="lazy"
        class="zone-map-img"
      />
    </div>
  </div>
</section>
