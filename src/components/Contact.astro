---
import { site, heroPhone, whatsappLink } from "../data/site";

const phoneDisplay = heroPhone();
---

<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="contact-info">
      <p class="section-label">Contact</p>
      <h2 class="section-title">Parlons de<br />votre projet</h2>
      <p class="contact-text">
        Un projet de menuiserie à Givors, Vienne ou dans les environs ?
        Décrivez-moi votre besoin via le formulaire ou écrivez-moi directement
        sur WhatsApp.
      </p>
      <div class="contact-methods">
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-method"
          aria-label="Contacter HDM Menuiserie sur WhatsApp"
        >
          <div class="method-icon green" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#25D366">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
            </svg>
          </div>
          <div class="method-text">
            <strong>WhatsApp</strong>
            <span>Réponse rapide — {phoneDisplay}</span>
          </div>
        </a>

        <a
          href={`tel:${site.phone}`}
          class="contact-method"
          aria-label={`Téléphoner à HDM Menuiserie au ${phoneDisplay}`}
        >
          <div class="method-icon brown" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8B5E3C" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.43 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </div>
          <div class="method-text">
            <strong>Téléphone</strong>
            <span>Lun–Ven, 8h–18h · {phoneDisplay}</span>
          </div>
        </a>

        <a
          href={`mailto:${site.email}`}
          class="contact-method"
          aria-label={`Envoyer un email à ${site.email}`}
        >
          <div class="method-icon blue" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3d6b8B" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
          </div>
          <div class="method-text">
            <strong>Email</strong>
            <span>{site.email}</span>
          </div>
        </a>
      </div>
    </div>

    <form
      class="form-card"
      name="devis"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/merci/"
    >
      <input type="hidden" name="form-name" value="devis" />
      <p hidden>
        <label>Ne pas remplir : <input name="bot-field" /></label>
      </p>

      <div class="form-title">Demande de devis</div>
      <p class="form-subtitle">Gratuit · Sans engagement · Réponse personnalisée</p>

      <div class="form-row">
        <div class="form-group">
          <label for="prenom">Prénom *</label>
          <input type="text" id="prenom" name="prenom" placeholder="Jean" required autocomplete="given-name" />
        </div>
        <div class="form-group">
          <label for="nom">Nom *</label>
          <input type="text" id="nom" name="nom" placeholder="Dupont" required autocomplete="family-name" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="tel">Téléphone *</label>
          <input type="tel" id="tel" name="telephone" placeholder="06 XX XX XX XX" required autocomplete="tel" />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="jean@email.fr" autocomplete="email" />
        </div>
      </div>

      <div class="form-group">
        <label for="prestation">Type de prestation *</label>
        <select id="prestation" name="prestation" required>
          <option value="" disabled selected>Sélectionnez...</option>
          <option>Menuiserie intérieure (portes, escaliers...)</option>
          <option>Menuiserie extérieure (fenêtres, volets...)</option>
          <option>Agencement sur mesure (cuisine, dressing...)</option>
          <option>Rénovation (parquet, terrasse...)</option>
          <option>Fabrication meuble sur mesure</option>
          <option>Autre / Je ne sais pas encore</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="ville">Ville du chantier *</label>
          <input type="text" id="ville" name="ville" placeholder="Givors, Vienne..." required />
        </div>
        <div class="form-group">
          <label for="delai">Délai souhaité</label>
          <select id="delai" name="delai">
            <option value="">Pas de contrainte</option>
            <option>Urgent (moins d'1 mois)</option>
            <option>Sous 3 mois</option>
            <option>Sous 6 mois</option>
            <option>Je m'organise</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="description">Décrivez votre projet *</label>
        <textarea
          id="description"
          name="description"
          rows="4"
          placeholder="Quelques lignes sur ce que vous souhaitez faire : dimensions, matériaux souhaités, contexte..."
          required
        ></textarea>
      </div>

      <div class="form-group">
        <label for="source">Comment avez-vous entendu parler de moi ?</label>
        <select id="source" name="source">
          <option value="">Sélectionnez...</option>
          <option>Google</option>
          <option>Bouche à oreille / recommandation</option>
          <option>Pages Jaunes</option>
          <option>Réseaux sociaux</option>
          <option>Autre</option>
        </select>
      </div>

      <button type="submit" class="form-submit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13" />
          <polygon points="22 2 15 22 11 13 2 9 22 2" />
        </svg>
        Envoyer ma demande de devis
      </button>

      <p class="form-rgpd">
        En soumettant ce formulaire, vous acceptez que vos données soient
        utilisées uniquement pour traiter votre demande de devis. Voir les
        <a href="/mentions-legales/">mentions légales</a>.
      </p>
    </form>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[href="#contact"]').forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const target = document.getElementById("contact");
      if (!target) return;
      const top = target.getBoundingClientRect().top + window.scrollY - 70;
      window.scrollTo({ top, behavior: "smooth" });
      setTimeout(() => target.querySelector("input")?.focus(), 600);
    });
  });
</script>
