---
import { services } from "../data/services";
import { whatsappLink } from "../data/site";

const icons: Record<string, string> = {
  door: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="12" y2="12"/>',
  window:
    '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  layers:
    '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  tool: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  box: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>',
  quote:
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
};
---

<section class="services" id="services">
  <div class="services-header">
    <div>
      <p class="section-label">Savoir-faire</p>
      <h2 class="section-title">Prestations<br />de menuiserie</h2>
    </div>
    <p class="services-intro">
      De la conception à la pose, chaque projet est traité avec le même soin.
      Devis gratuit sous 48h sur Givors, Vienne et les communes alentour.
    </p>
  </div>

  <div class="services-grid">
    {services.map((s) => (
      <article class="service-card">
        <svg
          class="service-icon"
          viewBox="0 0 24 24"
          aria-hidden="true"
          set:html={icons[s.icon]}
        />
        <h3 class="service-name" set:html={s.name} />
        <p class="service-desc">{s.desc}</p>
        <ul class="service-list">
          {s.items.map((it) => <li>{it}</li>)}
        </ul>
      </article>
    ))}

    <article class="service-card cta">
      <svg class="service-icon" viewBox="0 0 24 24" aria-hidden="true" set:html={icons.quote} />
      <h3 class="service-name">Devis gratuit<br />sous 48h</h3>
      <p class="service-desc">
        Décrivez votre projet, je vous réponds rapidement avec une estimation
        claire et sans engagement.
      </p>
      <div class="service-actions">
        <a href="#contact" class="btn-primary" style="font-size: 0.8rem; padding: 0.7rem 1.2rem;">
          Formulaire devis
        </a>
        <a
          href={whatsappLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp"
          style="font-size: 0.8rem; padding: 0.7rem 1.2rem;"
        >
          WhatsApp
        </a>
      </div>
    </article>
  </div>
</section>
